# ============================================================
# Keil MDK 빌드 임시 산출물 — 빌드할 때마다 자동으로 다시 생김
# (obj/ 안의 .hex 릴리스 아카이브는 소중한 과거 버전 기록이므로
#  여기서 제외하지 않음 = git에 저장됨)
# ============================================================
obj/*.o
obj/*.obj
obj/*.d
obj/*.crf
obj/*.dep
obj/*.lnp
obj/*.tra
obj/*.iex
obj/*.axf
obj/*.htm
obj/*.build_log.htm
lst/

# Keil IDE 개인 설정 (창 배치, 브레이크포인트 등 — 코드와 무관)
*.uvopt
*.uvgui*

# 편집기 백업/임시 파일
*.bak
*~
